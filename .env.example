# Grok (X.AI) — default provider
GROK_API_KEY=your-grok-api-key-here

# OpenAI — for gpt-4o, o1, o3, o4 models + DALL-E image generation + TTS
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic — for claude models
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Web Search — for websearch tool (set one)
BRAVE_API_KEY=your-brave-search-api-key-here
TAVILY_API_KEY=your-tavily-api-key-here

# Browser — optional custom Chrome/Chromium path
CHROME_PATH=/path/to/chrome
